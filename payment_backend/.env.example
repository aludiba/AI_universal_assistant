NODE_ENV=production
PORT=8080
LOG_LEVEL=info

POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/aiua_billing
REDIS_URL=redis://127.0.0.1:6379

CALLBACK_BASE_URL=https://api.your-domain.com
ORDER_EXPIRE_MINUTES=30
MEMBERSHIP_SYNC_GRACE_SECONDS=8

# 与客户端约定的调用 token（可为空）
APP_CLIENT_TOKEN=
API_SIGN_SECRET=

# Alipay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_PATH=/v1/billing/alipay/notify

# WeChat Pay
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_PLATFORM_PUBLIC_KEY=
WECHAT_API_V3_KEY=
WECHAT_GATEWAY=https://api.mch.weixin.qq.com
WECHAT_NOTIFY_PATH=/v1/billing/wechat/notify
